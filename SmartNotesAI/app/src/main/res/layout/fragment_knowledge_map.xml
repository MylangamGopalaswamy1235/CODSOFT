<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/space_md">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Knowledge Tree"
            android:textColor="@color/primary_text"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/lv_tree"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:background="@color/surface_soft"
            android:divider="#EBEEF3"
            android:dividerHeight="1dp"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Graph View (Bonus)"
            android:textColor="@color/primary_text"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="@dimen/radius_lg"
            app:strokeColor="#EEF2F7"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="80dp"
                    android:layout_height="2dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="68dp"
                    android:background="#616161" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="62dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="70dp"
                    android:background="#616161" />

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/circle_node"
                    android:gravity="center"
                    android:text="AI" />

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="78dp"
                    android:background="@drawable/circle_node"
                    android:gravity="center"
                    android:text="DBMS" />

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="22dp"
                    android:layout_marginTop="78dp"
                    android:background="@drawable/circle_node"
                    android:gravity="center"
                    android:text="NLP" />

                <TextView
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="145dp"
                    android:background="@drawable/circle_node"
                    android:gravity="center"
                    android:text="ML" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</ScrollView>
